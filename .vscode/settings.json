{
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file",
  "oxc.suppressProgramErrors": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "always"
  },
  "[typescriptreact]": {
    "editor.codeActionsOnSave": {
      "source.fixAll.oxc": "explicit"
    },
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[typescript]": {
    "editor.codeActionsOnSave": {
      "source.fixAll.oxc": "explicit"
    }
  },
  "cSpell.words": [
    "orpc"
  ]
}
